# AXIOM Local Development Environment
# Copy to .env before running: cp env.local .env

# Harness Environment API (the a2a-hack CLI on your host)
ENV_API_URL=http://host.docker.internal:8090
CS_AGENT_URL=http://host.docker.internal:8090/cs-agent

# Per-service Environment API tokens (must match the harness's tokens)
PERSONAL_ENV_API_TOKEN=dev-user-token
CS_ENV_API_TOKEN=dev-agent-token

# Model selection
MODEL=gemini-2.5-flash

# Google AI configuration (free tier GCP key)
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_API_KEY=your-google-api-key-here
